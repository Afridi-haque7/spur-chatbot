# --- Server config ---
PORT=3001

# Comma-separated list of allowed CORS origins (the frontend URL).
CORS_ORIGIN=http://localhost:5173

# --- Database (Postgres) ---
# Local example (Docker / local Postgres):
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/spur?schema=public"
# Hosted example (Neon / Supabase / Render): paste the connection string they give you.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/spur?schema=public"

# --- Groq ---
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxx"
# Model is configurable so you can trade cost/quality without code changes.
# Good default: llama-3.3-70b-versatile. Cheaper/faster: llama-3.1-8b-instant.
GROQ_MODEL="llama-3.3-70b-versatile"

# --- LLM guardrails (cost control) ---
# Max tokens the model may generate per reply.
LLM_MAX_TOKENS=512
# How many past messages to include as context (keeps prompt size + cost bounded).
LLM_HISTORY_LIMIT=12
# Hard timeout for the LLM call, in milliseconds.
LLM_TIMEOUT_MS=20000

# --- Input limits ---
# Messages longer than this are rejected with a friendly error.
MAX_MESSAGE_LENGTH=4000
